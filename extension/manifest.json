{
  "manifest_version": 3,
  "name": "Antigravity Browser Bridge",
  "version": "1.0.0",
  "description": "Cầu nối bảo mật giúp AI Agent (Antigravity) kết nối và tương tác với trình duyệt.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:9090/",
    "http://localhost:9090/",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
